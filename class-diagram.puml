@startuml Route Optimization Class Diagram

' ==========================================
' JAVA BACKEND CLASSES
' ==========================================

package "com.route.server" {
  
  class RouteServer {
    - {static} PORT : int = 8080
    - graph : Graph
    - server : HttpServer
    --
    + {static} main(String[] args) : void
    + start() : void
    - handleRequest(HttpExchange exchange) : void
    - parseQueryParams(String query) : Map<String, String>
    - buildJsonResponse(Result result) : String
    - enableCORS(HttpExchange exchange) : void
    - sendResponse(HttpExchange, int, String) : void
  }
  
}

package "com.route.graph" {
  
  class Graph {
    - adjacencyList : Map<Node, List<Edge>>
    - nodes : List<Node>
    --
    + Graph()
    + addNode(Node node) : void
    + addEdge(Node source, Node dest, double weight) : void
    + addEdge(int sourceIdx, int destIdx, double weight) : void
    + getEdges(Node node) : List<Edge>
    + getNodes() : List<Node>
    + findNearestNode(double lat, double lng) : Node
    + loadSampleData() : void
    + size() : int
  }
  
  class Node {
    - id : String
    - latitude : double
    - longitude : double
    - name : String
    --
    + Node(String id, double lat, double lng, String name)
    + getId() : String
    + getLatitude() : double
    + getLongitude() : double
    + getName() : String
    + distanceTo(Node other) : double
    + equals(Object obj) : boolean
    + hashCode() : int
    + toString() : String
    --
    {static} - EARTH_RADIUS : double = 6371.0
  }
  
  class Edge {
    - source : Node
    - destination : Node
    - weight : double
    --
    + Edge(Node source, Node dest, double weight)
    + getSource() : Node
    + getDestination() : Node
    + getWeight() : double
    + toString() : String
  }
  
}

package "com.route.algorithm" {
  
  class DijkstraAlgorithm {
    - graph : Graph
    --
    + DijkstraAlgorithm(Graph graph)
    + findShortestPath(Node start, Node end) : Result
    + getDetailedPathCoordinates(int pointsPerSegment) : List<double[]>
    - reconstructPath(Map<Node, Node> prev, Node end) : List<Node>
    - interpolate(double start, double end, double fraction) : double
  }
  
  class Result {
    - path : List<Node>
    - distance : double
    - duration : double
    --
    + Result(List<Node> path, double dist, double dur)
    + getPath() : List<Node>
    + getDistance() : double
    + getDuration() : double
    + getPathCoordinates() : List<double[]>
    + setPath(List<Node> path) : void
    + setDistance(double distance) : void
    + setDuration(double duration) : void
  }
  
  class NodeDistance {
    - node : Node
    - distance : double
    --
    + NodeDistance(Node node, double distance)
    + getNode() : Node
    + getDistance() : double
    + compareTo(NodeDistance other) : int
  }
  
}

' ==========================================
' RELATIONSHIPS
' ==========================================

RouteServer --> Graph : uses
RouteServer --> DijkstraAlgorithm : creates
RouteServer ..> Result : receives

Graph "1" *-- "53" Node : contains
Graph "1" *-- "100+" Edge : manages

Edge "1" --> "1" Node : source
Edge "1" --> "1" Node : destination

DijkstraAlgorithm --> Graph : operates on
DijkstraAlgorithm ..> Result : returns
DijkstraAlgorithm ..> NodeDistance : uses internally

Result "1" *-- "1..*" Node : path

